# =============================================================================
# Lumina Scan — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All keys below are required for full functionality.

# Stellar Keypairs (Testnet)
# Generate at https://laboratory.stellar.org/#account-creator?network=test
SPONSOR_SECRET_KEY=S...   # Keypair that sponsors fees, reserves, and onboarding
RECIPIENT_SECRET_KEY=S... # Keypair that receives USDC payments

# MPP Secret Key (for signing 402 challenges)
MPP_SECRET_KEY=your_mpp_secret_key_here

# Groq API Key (for Llama 3.3 70B inference)
# Get yours at https://console.groq.com
GROQ_API_KEY=gsk_...

# Optional overrides (defaults shown)
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
